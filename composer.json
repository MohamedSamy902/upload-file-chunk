{
    "name": "mohamedsamy902/advanced-file-upload",
    "description": "A production-ready Laravel package for chunked uploads, image processing, URL downloads, multi-cloud storage, SSRF protection, and resumable file transfers.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "file-upload", "image", "storage", "s3", "chunk", "cdn", "thumbnail", "ssrf", "resumable"],
    "homepage": "https://github.com/MohamedSamy902/laravel-advanced-file-upload",
    "support": {
        "source": "https://github.com/MohamedSamy902/laravel-advanced-file-upload",
        "issues": "https://github.com/MohamedSamy902/laravel-advanced-file-upload/issues"
    },
    "authors": [
        {
            "name": "Mohamed Samy",
            "email": "mohamedsamy902@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "laravel/framework": ">=10.0",
        "intervention/image": "^3.0"
    },
    "suggest": {
        "league/flysystem-aws-s3-v3": "Required for Amazon S3 storage: ^3.0",
        "spatie/laravel-google-cloud-storage": "Required for Google Cloud Storage: ^2.0",
        "pion/laravel-chunk-upload": "Required for legacy chunked upload via HTTP Request: ^1.5",
        "spatie/image-optimizer": "Optional image optimization pipeline: ^1.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5|^11.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpstan/phpstan": "^1.10",
        "pion/laravel-chunk-upload": "^1.5"
    },
    "autoload": {
        "psr-4": {
            "MohamedSamy902\\AdvancedFileUpload\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MohamedSamy902\\AdvancedFileUpload\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MohamedSamy902\\AdvancedFileUpload\\AdvancedFileUploadServiceProvider"
            ],
            "aliases": {
                "FileUpload": "MohamedSamy902\\AdvancedFileUpload\\Facades\\FileUpload"
            }
        }
    },
    "scripts": {
        "test":    "vendor/bin/phpunit",
        "analyse": "vendor/bin/phpstan analyse src --level=6"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
