{
    "name": "mohamedsamy902/advanced-file-upload",
    "description": "A comprehensive file upload package for Laravel with cloud storage, image processing, chunked uploads, and more.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "file-upload", "image", "storage", "s3", "chunk", "cdn", "thumbnail"],
    "homepage": "https://github.com/MohamedSamy902/uplade-file-chunk",
    "authors": [
        {
            "name": "Mohamed Samy",
            "email": "mohamedsamy902@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.0",
        "laravel/framework": ">=9.0",
        "intervention/image": "^2.7",
        "pion/laravel-chunk-upload": "^1.5",
        "spatie/laravel-google-cloud-storage": "^2.0",
        "league/flysystem-aws-s3-v3": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "orchestra/testbench": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "MohamedSamy902\\AdvancedFileUpload\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MohamedSamy902\\AdvancedFileUpload\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MohamedSamy902\\AdvancedFileUpload\\AdvancedFileUploadServiceProvider"
            ],
            "aliases": {
                "FileUpload": "MohamedSamy902\\AdvancedFileUpload\\Facades\\FileUpload"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
